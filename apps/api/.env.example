PORT=4100
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
CORS_ALLOW_PRIVATE_NETWORK=true
AUTH_USERNAME=admin
AUTH_PASSWORD=replace-with-a-long-random-password
KITCHEN_CONCURRENCY=2
# Khoảng gia hạn sau ETA trước khi cảnh báo phiếu bếp; giới hạn 15-1440 phút.
KITCHEN_STALE_MINUTES=120
# Chỉ dùng cho migration dữ liệu queue cũ từng lưu theo giờ Việt Nam.
LEGACY_TIMEZONE_OFFSET_MINUTES=420
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=replace-with-local-mysql-password
DB_NAME=restaurant_casv2
